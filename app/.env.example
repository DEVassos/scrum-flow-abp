# ============================================================
# Template de variáveis de ambiente — copie para .env e ajuste
# ============================================================
#
# Uso: cp .env.example .env
# Depois preencha POSTGRES_PASSWORD e JWT_SECRET com valores reais.
#
# IMPORTANTE: o arquivo .env não é versionado (está no .gitignore).
# Nunca faça commit de .env com credenciais reais.

# --- Servidor ---
PORT=3000

# --- Banco de Dados (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=abp

# --- Autenticação JWT ---
# Gere uma string aleatória longa (ex: openssl rand -hex 32)
JWT_SECRET=
# Tempo de vida do token em segundos (ex: 600 = 10 minutos)
DEFAULT_EXPIRES_IN_SECONDS=600
