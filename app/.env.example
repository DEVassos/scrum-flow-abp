# ============================================================
# Template de variáveis de ambiente — copie para .env e ajuste
# ============================================================
#
# Uso: cp .env.example .env
# Depois preencha DATABASE_URL e JWT_SECRET com valores reais.
#
# IMPORTANTE: o arquivo .env não é versionado (está no .gitignore).
# Nunca faça commit de .env com credenciais reais.

# --- Servidor ---
PORT=3005

# --- Banco de Dados (PostgreSQL) ---
# A aplicação conecta via DATABASE_URL (string de conexão completa).
# Tanto o servidor quanto o `npm run db:init` usam esta variável.
#
# Observação: quando DATABASE_URL está definida, a conexão usa SSL
# obrigatório (ver src/database/db.js). Use um PostgreSQL que suporte
# SSL (ex.: Neon, Supabase, RDS). Exemplo (Neon):
#   DATABASE_URL=postgresql://USUARIO:SENHA@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Autenticação JWT ---
# Gere uma string aleatória longa (ex: openssl rand -hex 32)
JWT_SECRET=
# Tempo de vida do token em segundos (ex: 600 = 10 minutos)
DEFAULT_EXPIRES_IN_SECONDS=3600

# ------------------------------------------------------------
# (Legado) Variáveis POSTGRES_* — atualmente NÃO utilizadas.
# O src/database/db.js conecta apenas via DATABASE_URL; estas linhas
# ficam comentadas no código. Mantidas como referência caso a conexão
# por parâmetros individuais seja reativada no futuro.
# ------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=abp
